# Backend production example
PORT=4001
DATABASE_TARGET=local
DATABASE_URL="postgresql://postgres:password@localhost:5432/dbname"
DATABASE_URL_LOCAL="postgresql://postgres:password@localhost:5432/dbname"
DATABASE_URL_NEON="postgresql://user:password@host:5432/dbname?sslmode=require"
JWT_SECRET="replace-with-a-long-random-secret"
FRONTEND_URL="https://app.yournewdomain.com"
BACKEND_URL="https://api.yournewdomain.com"
NODE_ENV=production
BRANCHX_BASE_URL=https://10x.api.branchx.in
BRANCHX_PAYOUT_ENDPOINT=/service/payout/v2
BRANCHX_STATUS_CHECK_ENDPOINT=/service/status_check/v2
BRANCHX_API_TOKEN=your_branchx_api_token
BRANCHX_TIMEOUT_MS=60000
BRANCHX_LATITUDE=0
BRANCHX_LONGITUDE=0
BRANCHX_PAYOUT_SYNC_INTERVAL_MS=300000
BRANCHX_PAYOUT_SYNC_INITIAL_DELAY_MS=60000
